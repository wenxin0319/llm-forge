PORT=3001
JWT_SECRET=change-me-in-production

# Database — PostgreSQL
# Railway sets DATABASE_URL automatically when you add the Postgres plugin
# For local development, either set DATABASE_URL or the individual vars below
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llmforge

# Individual DB vars (used as fallback when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=llmforge

# CORS — Frontend origin
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
