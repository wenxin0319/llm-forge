PORT=3001
# Required — the app refuses to start without this set. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Admin account bootstrap — both required together, or neither. If unset, no
# admin account is created or modified at boot. If set, the account matching
# ADMIN_EMAIL is created (or promoted to admin) and its password hash is
# rotated to match ADMIN_PASSWORD whenever they diverge — so rotating the
# admin password in production is just changing this env var and redeploying.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Database — PostgreSQL
# Railway sets DATABASE_URL automatically when you add the Postgres plugin
# For local development, either set DATABASE_URL or the individual vars below
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llmforge

# Individual DB vars (used as fallback when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=llmforge

# CORS — Frontend origin
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# GPU telemetry: auto tries nvidia-smi and falls back to labeled demo data;
# real fails closed without nvidia-smi; mock always returns deterministic demo data.
GPU_METRICS_MODE=auto
